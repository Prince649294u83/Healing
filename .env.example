# Environment Variables Example
# Copy this file to .env and configure the values

# Database configuration (Required for db package)
# Replace with your local or remote PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/matangi_healings"

# The port for the main website (Optional, defaults to 5173)
# PORT=5173

# The port for the mockup sandbox (Optional, defaults to 5174)
# MOCKUP_PORT=5174
